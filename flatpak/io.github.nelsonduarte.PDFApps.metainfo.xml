<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.nelsonduarte.PDFApps</id>
  <name>PDFApps</name>
  <summary>Fast, offline, subscription-free PDF editor</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      PDFApps is a fast, offline, all-in-one PDF editor and manager. No subscriptions,
      no cloud uploads, no account required — your files never leave your computer.
    </p>
    <p>13 built-in tools:</p>
    <ul>
      <li>Split PDFs by page ranges</li>
      <li>Merge multiple PDFs with drag-and-drop ordering</li>
      <li>Rotate, extract, and reorder pages</li>
      <li>Compress with three quality levels</li>
      <li>Encrypt and decrypt with passwords</li>
      <li>Add watermarks and stamps</li>
      <li>OCR for scanned documents (5 languages)</li>
      <li>Convert to PNG, JPG, DOCX, or TXT</li>
      <li>Visual editor: redact, text, images, signatures, highlights, notes</li>
      <li>Import TXT, images, or Markdown to PDF</li>
      <li>View document metadata</li>
    </ul>
    <p>Features include continuous scroll viewer, presentation mode (F5), fullscreen
       (F11), search, tabbed viewing, dark/light themes, and 8 language interface.</p>
  </description>

  <launchable type="desktop-id">io.github.nelsonduarte.PDFApps.desktop</launchable>

